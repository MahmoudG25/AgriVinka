rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getUserRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && (getUserRole(request.auth.uid) in ['admin', 'superAdmin']);
    }

    function isSuperAdmin() {
      return isAuth() && getUserRole(request.auth.uid) == 'superAdmin';
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isRoleUnchanged() {
      return request.resource.data.role == resource.data.role;
    }

    function isLimitedRole() {
      return request.resource.data.role in ['student', 'admin', 'superAdmin'];
    }

    function isValidUserCreate() {
      // Regular users can only create their own profile as student.
      return request.auth.uid == request.resource.id
        && request.resource.data.role == 'student'
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0;
    }

    function isValidUserUpdate() {
      // Do not allow self role escalation. Admins can update users except role field only by superAdmin.
      return request.resource.data.keys().hasOnly([
        'displayName', 'email', 'photoURL', 'phoneNumber', 'role', 'status', 'preferences', 'subscriptionStatus', 'lastLoginAt', 'updatedAt'
      ])
      && (isSuperAdmin() || isOwner(request.resource.id) ? true : isAdmin())
      && (isOwner(request.resource.id) ? request.resource.data.role == resource.data.role : true)
      && (isAdmin() && !isSuperAdmin() ? request.resource.data.role == resource.data.role : true);
    }

    // Admin-only: update AI assistant control fields on user documents
    function isValidAdminAiUpdate() {
      return isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['aiEnabled', 'aiUsageCount', 'aiLimitOverride', 'updatedAt']);
    }

    // Users can increment their own aiUsageCount by exactly 1
    function isValidUserAiUsageIncrement(uid) {
      return isAuth()
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['aiUsageCount', 'updatedAt'])
        && request.resource.data.aiUsageCount == resource.data.aiUsageCount + 1;
    }

    // Certificates (public read for verification)
    match /certificates/{certId} {
      allow read: if true;
      allow create: if isAuth() && (request.resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Public-safe verification collection used by /verify/:certificateId
    match /certificates_public/{certId} {
      // Anyone can verify by ID
      allow get, list: if true;

      // Frontend writes when issuing certificates (must be signed in)
      allow create, update: if isAuth();

      // No client deletes
      allow delete: if false;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isValidUserCreate() || (isSuperAdmin() && request.auth.uid == uid && isLimitedRole());
      allow update: if (isOwner(uid) && isValidUserUpdate())
                    || (isAdmin() && isValidUserUpdate())
                    || isValidAdminAiUpdate()
                    || isValidUserAiUsageIncrement(uid);
      allow delete: if isSuperAdmin();

      match /aiScans/{scanId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid);
        allow update, delete: if isOwner(uid);
      }


      match /enrollments/{courseId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) || isAdmin();

        match /lessonProgress/{lessonId} {
          allow read: if isOwner(uid) || isAdmin();
          allow write: if isOwner(uid);
        }
      }

      match /roadmapEnrollments/{roadmapId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) || isAdmin();
      }

      match /favorites/{courseId} {
        allow read, write: if isOwner(uid);
      }

      match /trainingApplications/{appId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) || isAdmin();
        allow update, delete: if isOwner(uid) || isAdmin();
      }

      match /ai_usage/{usageId} {
        allow read, write: if isOwner(uid);
        allow delete: if false;
      }
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();

      // Legacy lessons subcollection
      match /lessons/{lessonId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // New modules subcollection
      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /roadmaps/{roadmapId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Certificate template settings (branding — safe for public read)
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /siteConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /ai_sessions/{sessionId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());

      match /messages/{messageId} {
        // CREATE: must include userId matching the requester
        allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
        // READ/DELETE: verify via parent session ownership (avoids resource.data in list queries)
        allow read: if isAuth() && (
          get(/databases/$(database)/documents/ai_sessions/$(sessionId)).data.userId == request.auth.uid
          || isAdmin()
        );
        allow update, delete: if isAdmin();
      }
    }

    // AI global settings — admin writes, any authenticated user can read
    match /ai_settings/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // AI interaction logs — admin reads, authenticated users write their own
    match /ai_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /courseRequests/{requestId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }

    match /trainings/{trainingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Top-level trainingApplications
    match /trainingApplications/{appId} {
      allow create: if isAuth();
      allow read: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /site_ui/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}