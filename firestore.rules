rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor'
      );
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Certificates (public read for verification)
    match /certificates/{certId} {
      allow read: if true;
      allow create: if isAuth() && (request.resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Public-safe verification collection used by /verify/:certificateId
    match /certificates_public/{certId} {
      // Anyone can verify by ID
      allow get, list: if true;

      // Frontend writes when issuing certificates (must be signed in)
      allow create, update: if isAuth();

      // No client deletes
      allow delete: if false;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      match /enrollments/{courseId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) || isAdmin();

        match /lessonProgress/{lessonId} {
          allow read: if isOwner(uid) || isAdmin();
          allow write: if isOwner(uid);
        }
      }

      match /roadmapEnrollments/{roadmapId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) || isAdmin();
      }

      match /favorites/{courseId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid);
      }

      match /aiScans/{scanId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid);
      }

      match /trainingApplications/{appId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) || isAdmin();
      }
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();

      // Legacy lessons subcollection
      match /lessons/{lessonId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // New modules subcollection
      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /roadmaps/{roadmapId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Certificate template settings (branding — safe for public read)
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /siteConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /courseRequests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /trainings/{trainingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Top-level trainingApplications
    match /trainingApplications/{appId} {
      allow create: if isAuth();
      allow read: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /site_ui/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}