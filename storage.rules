rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuth() { return request.auth != null; }
    function isAdmin() { 
      return isAuth() && (
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'editor'
      );
    }
    
    // Public reading of all assets
    match /{allPaths=**} {
      allow read: if true;
    }

    // Only Admin can write to global paths (courses, system assets)
    match /courses/{allPaths=**} {
      allow write: if isAdmin();
    }
    
    // Users can only upload and modify within their own directory
    match /users/{userId}/{allPaths=**} {
      allow read: if isAuth(); // Open read to auth, or true for public images like avatars
      allow write: if request.auth.uid == userId;
    }
    
    // Fallback: block all other writes
    match /{allPaths=**} {
      allow write: if isAdmin();
    }
  }
}
